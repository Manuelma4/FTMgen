# Copier ce fichier vers .env uniquement sur le serveur de deploiement.
# Ne jamais commiter le .env reel ni y laisser une valeur secrete vide en production.

# Application
FTM_ENVIRONMENT=production
FTM_PUBLIC_URL=https://ftm.moduo.fr

# Authentification OIDC / Keycloak
FTM_AUTH_REQUIRED=true
FTM_SESSION_COOKIE_SECURE=true
FTM_AUTH_DB_PATH=/app/output/auth.sqlite3
# Optionnel: rattache les analyses historiques sans proprietaire a un compte OIDC donne.
FTM_LEGACY_OWNER_SUB=

# Generer une valeur aleatoire longue sur le serveur; ne pas reutiliser un autre secret.
SESSION_SECRET=
# Format attendu: https://auth.moduo.fr/realms/<realm-existant>
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=ftmgen
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://ftm.moduo.fr/api/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://ftm.moduo.fr/
OIDC_SCOPES=openid profile email
OIDC_HTTP_TIMEOUT_SECONDS=10
FTM_SESSION_COOKIE_NAME=ftmgen_session
FTM_SESSION_TTL_SECONDS=28800
FTM_OIDC_STATE_TTL_SECONDS=600

# LLM LIHA optionnel. Laisser FTM_USE_LLM=false si le service n'est pas configure.
FTM_USE_LLM=false
FTM_LLM_TIMEOUT=600
LIHA_CHAT_COMPLETIONS_URL=
LIHA_CHAT_MODEL=
LIHA_CHAT_TOKEN=
LIHA_CHAT_TIMEOUT_SECONDS=15
